// Matches the ModeSwitcher pill so the header toolbar reads as one control set.
.root
  height 32px
  border-radius 50px
  background-color #F4F4F4
  display inline-flex
  align-items center
  position relative
  top 1px
  padding 3px
  margin-right 8px
  -webkit-user-drag none
  user-select none

.btn
  min-width 28px
  height 26px
  border none
  background transparent
  border-radius 50px
  display flex
  align-items center
  justify-content center
  cursor pointer
  color rgba(90, 90, 90, 0.7)
  padding 0
  &:hover:not(:disabled)
    color rgba(90, 90, 90, 1)
    background-color rgba(0, 0, 0, 0.06)
  &:disabled
    opacity 0.35
    cursor default
  &:focus-visible
    outline none
    box-shadow 0 0 0 2px #ffffff, 0 0 0 4px #333333

.glyph-small
  font-size 11px
  font-weight 700
  line-height 1

.glyph-large
  font-size 17px
  font-weight 700
  line-height 1

.value
  min-width 42px
  height 26px
  border none
  background transparent
  cursor pointer
  color rgba(90, 90, 90, 0.85)
  font-size 12px
  padding 0 2px
  font-variant-numeric tabular-nums
  &:hover
    color rgba(90, 90, 90, 1)
  &:focus-visible
    outline none
    box-shadow 0 0 0 2px #ffffff, 0 0 0 4px #333333

body[data-theme="dark"]
  .root
    background-color #3A404C
  .btn, .value
    color rgba(200, 200, 200, 0.7)
    &:hover:not(:disabled)
      color rgba(255, 255, 255, 0.95)
      background-color rgba(255, 255, 255, 0.08)

body[data-theme="solarized-dark"]
  .root
    background-color #002B36

apply-theme(theme)
  body[data-theme={theme}]
    .root
      background-color get-theme-var(theme, 'borderColor')
    .btn, .value
      color get-theme-var(theme, 'text-color')

for theme in $themes
  apply-theme(theme)
