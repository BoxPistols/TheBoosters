.root
  position relative
  z-index 2
  width 80vw
  max-width 1100px
  height 80vh
  margin 8vh auto 0
  background-color #1e1e22
  color #ddd
  border-radius 6px
  box-shadow 0 8px 40px rgba(0,0,0,0.5)
  display flex
  flex-direction column
  overflow hidden

.header
  display flex
  align-items center
  justify-content space-between
  padding 14px 20px
  border-bottom 1px solid #333

.title
  font-size 16px
  font-weight 700

.close
  background transparent
  border none
  color #999
  font-size 22px
  line-height 1
  cursor pointer
  padding 0 6px
  &:hover
    color #fff

.summary
  padding 8px 20px
  font-size 13px
  color #aaa

.warning
  margin 0 20px 8px
  padding 8px 12px
  font-size 12px
  color #ffd479
  background-color rgba(255,180,0,0.1)
  border 1px solid rgba(255,180,0,0.3)
  border-radius 4px

.toolbar
  display flex
  align-items center
  justify-content space-between
  padding 6px 20px 12px
  border-bottom 1px solid #333

.filters
  display flex
  gap 6px

.tab
  background transparent
  border 1px solid #444
  color #bbb
  padding 4px 12px
  border-radius 4px
  cursor pointer
  font-size 12px
  &:hover
    border-color #666

.tab--active
  @extend .tab
  background-color #E10051
  border-color #E10051
  color #fff

.actions
  display flex
  gap 8px

.action
  background-color #2c2c33
  border 1px solid #444
  color #ddd
  padding 4px 12px
  border-radius 4px
  cursor pointer
  font-size 12px
  &:hover:not(:disabled)
    border-color #666
  &:disabled
    opacity 0.4
    cursor default

.action--danger
  @extend .action
  &:hover:not(:disabled)
    background-color #c0392b
    border-color #c0392b
    color #fff

.grid
  flex 1
  overflow-y auto
  padding 16px 20px
  display grid
  grid-template-columns repeat(auto-fill, minmax(150px, 1fr))
  grid-gap 14px
  align-content start

.empty
  grid-column 1 / -1
  text-align center
  color #777
  padding 40px 0

.card
  position relative
  background-color #26262b
  border 2px solid transparent
  border-radius 6px
  overflow hidden
  cursor pointer
  transition border-color 0.12s
  &:hover
    border-color #555

.card--selected
  @extend .card
  border-color #E10051

.thumb
  position relative
  height 110px
  background-color #16161a
  display flex
  align-items center
  justify-content center
  img
    max-width 100%
    max-height 100%
    object-fit contain

.badge-unused
  position absolute
  top 6px
  left 6px
  background-color rgba(200,60,50,0.9)
  color #fff
  font-size 10px
  padding 1px 6px
  border-radius 3px

.meta
  padding 6px 8px

.filename
  font-size 12px
  white-space nowrap
  overflow hidden
  text-overflow ellipsis

.sub
  font-size 11px
  color #999
  white-space nowrap
  overflow hidden
  text-overflow ellipsis

.check
  position absolute
  top 6px
  right 6px
