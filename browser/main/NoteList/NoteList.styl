$control-height = 30px

.root
  absolute left bottom
  top $topBar-height - 1
  background-color $ui-noteList-backgroundColor

.control
  absolute top left right
  user-select none
  height $control-height
  font-size 12px
  line-height 25px
  display flex
  background-color $ui-noteList-backgroundColor
  color $ui-inactive-text-color

.control-sortBy
  flex 1
  padding-left 22px

.control-sortBy-select
  appearance: none;
  margin-left 5px
  color $ui-inactive-text-color
  padding 0
  border none
  background-color transparent
  outline none
  cursor pointer
  font-size 12px
  &:hover
    transition 0.2s
    color $ui-text-color

.control-button-area
  margin-right 12px
  flex-shrink 0
  white-space nowrap

.control-button
  width 25px
  padding 0
  background-color transparent
  border none
  color alpha($ui-inactive-text-color, 60%)
  transition 0.15s
  &:active, &:active:hover
    color $ui-inactive-text-color
  &:hover
    color $ui-inactive-text-color

.control-button--active
  @extend .control-button
  color $ui-inactive-text-color
  &:hover
    color $ui-inactive-text-color

.list
  absolute left right bottom
  top $control-height
  overflow auto

// Bulk-action bar shown when 2+ notes are selected (multi-select via
// cmd/shift-click). Overlays just below the sort/view header.
$bulk-bar-height = 34px
.bulk-bar
  absolute left right
  top $control-height
  height $bulk-bar-height
  z-index 5
  display flex
  align-items center
  justify-content space-between
  padding 0 14px
  font-size 12px
  background-color alpha($ui-button--active-backgroundColor, 90%)
  color $ui-text-color
  border-bottom $ui-border

.bulk-count
  font-weight 700
  min-width 0
  overflow hidden
  text-overflow ellipsis
  white-space nowrap

.bulk-actions
  display flex
  align-items center
  flex-shrink 0
  gap 4px

// Compact icon buttons so 3-4 actions fit the narrow (~280px) note panel
// without wrapping/overlapping. Labels are exposed via title + aria-label.
.bulk-action
  width 26px
  height 24px
  display flex
  align-items center
  justify-content center
  background transparent
  border 1px solid alpha($ui-text-color, 22%)
  border-radius 4px
  color $ui-text-color
  cursor pointer
  font-size 12px
  padding 0
  &:hover
    background-color alpha($ui-text-color, 10%)
  &:focus-visible
    outline 2px solid #1EC38B
    outline-offset -2px

.bulk-action--active
  @extend .bulk-action
  background-color #1EC38B
  border-color #1EC38B
  color #ffffff
  &:hover
    background-color #1EC38B

.bulk-action--danger
  @extend .bulk-action
  color #c0392b
  border-color alpha(#c0392b, 45%)
  &:hover
    background-color alpha(#c0392b, 12%)

.bulk-action--restore
  @extend .bulk-action
  color #27ae60
  border-color alpha(#27ae60, 45%)
  &:hover
    background-color alpha(#27ae60, 12%)

// Floating tag editor for bulk-selected notes. Overlays the top of the list
// as a dropdown so the fixed list offset stays correct regardless of how many
// tag chips wrap.
.bulk-tag-editor
  absolute left right
  top $control-height + $bulk-bar-height
  z-index 6
  display flex
  flex-direction column
  gap 6px
  padding 8px 12px
  max-height 170px
  overflow-y auto
  background-color $ui-noteList-backgroundColor
  border-bottom $ui-border
  box-shadow 0 4px 8px alpha(#000000, 12%)

.bulk-tag-list
  display flex
  flex-wrap wrap
  gap 5px

.bulk-tag
  display inline-flex
  align-items center
  max-width 100%
  padding 2px 4px 2px 7px
  border-radius 4px
  font-size 12px
  color $ui-text-color
  background-color alpha($ui-button--active-backgroundColor, 90%)

.bulk-tag-label
  overflow hidden
  text-overflow ellipsis
  white-space nowrap

.bulk-tag-remove
  display inline-flex
  align-items center
  justify-content center
  margin-left 4px
  width 16px
  height 16px
  padding 0
  border none
  border-radius 3px
  background transparent
  color alpha($ui-text-color, 60%)
  cursor pointer
  font-size 10px
  &:hover
    color $ui-text-color
    background-color alpha($ui-text-color, 12%)

.bulk-tag-input
  width 100%
  box-sizing border-box
  padding 5px 8px
  border 1px solid alpha($ui-text-color, 22%)
  border-radius 4px
  background-color $ui-backgroundColor
  color $ui-text-color
  font-size 12px
  outline none
  &:focus
    border-color #1EC38B

.list--bulk
  @extend .list
  top $control-height + $bulk-bar-height

$moving-bar-height = 28px
.moving-bar
  absolute left right
  top $control-height
  height $moving-bar-height
  z-index 6
  display flex
  align-items center
  justify-content center
  gap 6px
  font-size 11px
  background-color alpha(#2ecc71, 12%)
  color #2ecc71
  border-bottom 1px solid alpha(#2ecc71, 25%)

.moving-spinner
  width 10px
  height 10px
  border-radius 50%
  border 1.5px solid alpha(#2ecc71, 35%)
  border-top-color #2ecc71
  animation notelist-spin 0.6s linear infinite

.loading-overlay
  absolute top left right bottom
  z-index 10
  display flex
  flex-direction column
  align-items center
  justify-content center
  gap 8px
  color $ui-inactive-text-color
  font-size 12px
  background-color alpha($ui-noteList-backgroundColor, 85%)
  pointer-events none

.loading-spinner
  width 20px
  height 20px
  border-radius 50%
  border 2px solid alpha($ui-inactive-text-color, 25%)
  border-top-color $ui-inactive-text-color
  animation notelist-spin 0.7s linear infinite

@keyframes notelist-spin
  to
    transform rotate(360deg)

apply-theme(theme)
  body[data-theme={theme}]
    .root
      border-color get-theme-var(theme, 'borderColor')
      background-color get-theme-var(theme, 'noteList-backgroundColor')

    .control
      background-color get-theme-var(theme, 'noteList-backgroundColor')
      border-color get-theme-var(theme, 'borderColor')

    .control-sortBy-select
      &:hover
        transition 0.2s
        color get-theme-var(theme, 'text-color')
        background-color: get-theme-var(theme, 'noteList-backgroundColor')

    .control-button
      color get-theme-var(theme, 'inactive-text-color')
      &:hover
        color get-theme-var(theme, 'text-color')

    .control-button--active
      color get-theme-var(theme, 'text-color')
      &:active
        color get-theme-var(theme, 'text-color')

    .bulk-action
      color get-theme-var(theme, 'text-color')
      border-color get-theme-var(theme, 'borderColor')

    .bulk-tag-editor
      background-color get-theme-var(theme, 'noteList-backgroundColor')
      border-color get-theme-var(theme, 'borderColor')

    .bulk-tag
      color get-theme-var(theme, 'text-color')
      background-color get-theme-var(theme, 'button--active-backgroundColor')

    .bulk-tag-input
      background-color get-theme-var(theme, 'backgroundColor')
      color get-theme-var(theme, 'text-color')
      border-color get-theme-var(theme, 'borderColor')

for theme in 'white' 'dark' 'solarized-dark' 'dracula'
  apply-theme(theme)

for theme in $themes
  apply-theme(theme)
