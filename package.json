{
  "name": "the-boosters",
  "productName": "The Boosters",
  "version": "0.16.12",
  "main": "index.js",
  "description": "The Boosters — a modernized, independent successor to Boostnote (originally © BoostIO, GPL-3.0)",
  "license": "GPL-3.0",
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "postinstall": "node node_modules/electron/install.js",
    "start": "electron .",
    "compile": "vite build --config vite.renderer.config.mjs",
    "test": "npm run ava && npm run jest",
    "ava": "cross-env NODE_ENV=test ava --serial",
    "jest": "jest",
    "fix": "eslint . --fix",
    "lint": "eslint .",
    "dev": "cross-env NODE_ENV=development NODE_OPTIONS=--openssl-legacy-provider node dev-scripts/dev.js",
    "restart": "pnpm run compile && pnpm start",
    "watch": "cross-env NODE_OPTIONS=--openssl-legacy-provider webpack-dev-server --hot",
    "dist": "npm run compile && electron-builder",
    "dist:mac": "npm run compile && electron-builder --mac",
    "dist:win": "npm run compile && electron-builder --win --x64",
    "dist:dir": "npm run compile && electron-builder --dir",
    "compile:vite": "vite build --config vite.renderer.config.mjs",
    "compile:webpack": "cross-env BABEL_ENV=production NODE_ENV=production NODE_OPTIONS=--openssl-legacy-provider webpack --config webpack-production.config.js --bail",
    "check-esm-cjs": "node scripts/check-esm-cjs-compat.mjs",
    "pre-release": "node scripts/pre-release-check.mjs"
  },
  "config": {
    "electron-version": "28.3.3"
  },
  "build": {
    "appId": "io.boxpistols.theboosters",
    "productName": "The Boosters",
    "copyright": "GPL-3.0, inherited from BoostIO (Boostnote)",
    "asar": false,
    "afterPack": "scripts/after-pack-adhoc-sign.js",
    "directories": {
      "output": "release",
      "app": "."
    },
    "files": [
      "index.js",
      "lib/**/*",
      "compiled/**/*",
      "resources/**/*",
      "extra_scripts/**/*",
      "dictionaries/**/*",
      "locales/**/*",
      "node_modules/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "BoxPistols",
      "repo": "TheBoosters",
      "releaseType": "release"
    },
    "mac": {
      "icon": "resources/app.icns",
      "category": "public.app-category.productivity",
      "identity": null,
      "artifactName": "The-Boosters-${version}-${arch}.${ext}",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "win": {
      "icon": "resources/app.ico",
      "artifactName": "The-Boosters-Setup-${version}.${ext}",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BoxPistols/TheBoosters.git"
  },
  "keywords": [
    "the-boosters",
    "note",
    "markdown",
    "snippet",
    "storage",
    "electron"
  ],
  "author": "BoxPistols (https://github.com/BoxPistols)",
  "contributors": [
    "Kazu Yokomizo (https://github.com/kazup01)",
    "dojineko (https://github.com/dojineko)",
    "Romain Bazile (https://github.com/gromain)",
    "Bruno Paz (https://github.com/brpaz)",
    "Fabian Mueller (https://github.com/dotcs)",
    "Yoshihisa Mochihara (https://github.com/yosmoc)",
    "Mike Resoli (https://github.com/mikeres0)",
    "tjado (https://github.com/tejado)",
    "Sota Sugiura (https://github.com/sota1235)",
    "Milo Todt (https://github.com/MiloTodt)"
  ],
  "bugs": {
    "url": "https://github.com/BoxPistols/TheBoosters/issues"
  },
  "homepage": "https://github.com/BoxPistols/TheBoosters",
  "dependencies": {
    "@electron/remote": "^2.1.3",
    "@enyaxu/markdown-it-anchor": "^5.0.2",
    "@google/genai": "^2.10.0",
    "@hikerpig/markdown-it-toc-and-anchor": "^4.5.0",
    "@rokt33r/js-sequence-diagrams": "^2.0.6-2",
    "@rokt33r/markdown-it-math": "^4.0.1",
    "@rokt33r/season": "^5.3.0",
    "@susisu/mte-kernel": "^2.0.0",
    "chart.js": "^2.7.2",
    "clone": "^1.0.4",
    "codemirror": "^5.40.2",
    "codemirror-mode-elixir": "^1.1.1",
    "command-exists": "^1.2.9",
    "connected-react-router": "^6.4.0",
    "copy-to-clipboard": "^3.0.6",
    "electron-config": "^1.0.0",
    "escape-string-regexp": "^5.0.0",
    "file-uri-to-path": "^1.0.0",
    "file-url": "^4.0.0",
    "filenamify": "^7.0.2",
    "flowchart.js": "1.10.0",
    "font-awesome": "^4.3.0",
    "fs-extra": "^11.3.5",
    "grunt-cli": "^1.5.0",
    "highlight.js": "^11.11.1",
    "history": "^4.9.0",
    "i18n-2": "^0.7.2",
    "iconv-lite": "^0.4.19",
    "invert-color": "^2.0.0",
    "js-message": "^1.0.7",
    "js-yaml": "^5.2.1",
    "jsonlint-mod": "^1.7.4",
    "katex": "^0.10.1",
    "lodash": "^4.17.19",
    "lodash-move": "^1.1.1",
    "markdown-it": "^6.0.1",
    "markdown-it-abbr": "^1.0.4",
    "markdown-it-admonition": "^1.0.4",
    "markdown-it-emoji": "^1.1.1",
    "markdown-it-footnote": "^3.0.0",
    "markdown-it-imsize": "^2.0.1",
    "markdown-it-kbd": "^1.1.1",
    "markdown-it-multimd-table": "^2.0.1",
    "markdown-it-plantuml": "^1.1.0",
    "markdown-it-smartarrows": "^1.0.1",
    "markdown-it-sub": "^1.0.0",
    "markdown-it-sup": "^1.0.0",
    "markdown-toc": "^1.2.0",
    "markdownlint": "^0.11.0",
    "mdurl": "^1.0.1",
    "mermaid": "^8.5.2",
    "moment": "^2.10.3",
    "mousetrap": "^1.6.2",
    "mousetrap-global-bind": "^1.1.0",
    "node-ipc": "^8.1.0",
    "openai": "^6.45.0",
    "prettier": "^1.18.2",
    "prop-types": "^15.7.2",
    "query-string": "^9.4.1",
    "raphael": "^2.2.7",
    "react": "^16.8.6",
    "react-autosuggest": "^9.4.0",
    "react-codemirror": "^1.0.0",
    "react-color": "^2.2.2",
    "react-composition-input": "^1.1.1",
    "react-css-modules": "^4.7.9",
    "react-debounce-render": "^4.0.1",
    "react-dom": "^16.8.6",
    "react-emoji-render": "^1.1.0",
    "react-image-carousel": "^2.0.18",
    "react-redux": "^7.0.3",
    "react-router-dom": "^5.0.0",
    "react-sortable-hoc": "^0.6.7",
    "react-transition-group": "^2.5.0",
    "redux": "^3.5.2",
    "sander": "^0.5.1",
    "sanitize-html": "^1.18.2",
    "striptags": "^2.2.1",
    "turndown": "^4.0.2",
    "turndown-plugin-gfm": "^1.0.2",
    "typo-js": "^1.0.3",
    "unique-slug": "2.0.0",
    "uuid": "^3.2.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.3",
    "ava": "^0.25.0",
    "babel-core": "^6.26.3",
    "babel-jest": "^22.4.3",
    "babel-loader": "^6.2.0",
    "babel-plugin-add-module-exports": "^0.2.1",
    "babel-plugin-react-transform": "^2.0.0",
    "babel-plugin-webpack-alias": "^2.1.1",
    "babel-preset-env": "^1.6.1",
    "babel-preset-es2015": "^6.3.13",
    "babel-preset-react": "^6.24.1",
    "babel-preset-react-hmre": "^1.0.1",
    "babel-register": "^6.11.6",
    "browser-env": "^3.2.5",
    "color": "^3.0.0",
    "concurrently": "^3.6.1",
    "cross-env": "^5.2.1",
    "css": "^2.2.4",
    "css-loader": "^0.19.0",
    "devtron": "^1.1.0",
    "dom-storage": "^2.0.2",
    "electron": "^28.3.3",
    "electron-builder": "^25.1.8",
    "electron-debug": "^2.2.0",
    "electron-devtools-installer": "^2.2.4",
    "electron-packager": "^12.2.0",
    "eslint": "^4.18.2",
    "eslint-config-prettier": "^6.10.0",
    "eslint-config-standard": "^6.2.1",
    "eslint-config-standard-jsx": "^3.2.0",
    "eslint-plugin-prettier": "^3.1.2",
    "eslint-plugin-react": "^7.8.2",
    "eslint-plugin-standard": "^3.0.1",
    "faker": "^3.1.0",
    "grunt": "^0.4.5",
    "grunt-electron-installer": "2.1.0",
    "husky": "^1.1.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^22.4.3",
    "jest-localstorage-mock": "^2.2.0",
    "jsdom": "^9.4.2",
    "json-loader": "^0.5.4",
    "merge-stream": "^1.0.0",
    "mock-require": "^3.0.1",
    "nib": "^1.2.0",
    "react-input-autosize": "^1.1.0",
    "react-test-renderer": "^16.8.6",
    "redux-devtools": "^3.5.0",
    "redux-devtools-dock-monitor": "^1.1.3",
    "redux-devtools-log-monitor": "^1.4.0",
    "signale": "^1.4.0",
    "standard": "^8.4.0",
    "style-loader": "^0.12.4",
    "stylus": "^0.52.4",
    "stylus-loader": "^2.5.1",
    "vite": "^6.4.3",
    "vite-plugin-electron-renderer": "^1.0.0",
    "webpack": "^1.15.0",
    "webpack-dev-server": "^1.16.5"
  },
  "optionalDependencies": {
    "grunt-electron-installer-debian": "^0.5.0",
    "grunt-electron-installer-redhat": "^0.3.1"
  },
  "optional": false,
  "ava": {
    "files": [
      "tests/**/*-test.js"
    ],
    "require": [
      "babel-register",
      "./tests/helpers/setup-browser-env.js",
      "./tests/helpers/setup-electron-mock.js"
    ],
    "babel": "inherit"
  },
  "jest": {
    "testURL": "http://localhost/",
    "moduleNameMapper": {
      "\\.(jpg|jpeg|png|gif|eot|otf|webp|svg|ttf|woff|woff2|mp4|webm|wav|mp3|m4a|aac|oga)$": "<rootDir>/__mocks__/fileMock.js",
      "\\.(css|less|styl)$": "identity-obj-proxy",
      "^escape-string-regexp$": "<rootDir>/tests/shims/escape-string-regexp.js",
      "^file-url$": "<rootDir>/tests/shims/file-url.js",
      "^filenamify$": "<rootDir>/tests/shims/filenamify.js",
      "^query-string$": "<rootDir>/tests/shims/query-string.js"
    },
    "setupFiles": [
      "<rootDir>/tests/jest.js",
      "jest-localstorage-mock"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm run lint"
    }
  },
  "volta": {
    "node": "22.22.3"
  }
}
