# pnpm: hoisted (flat) node_modules so the legacy webpack 1 build can resolve
# implicit/undeclared dependencies the same way npm did. Without this, pnpm's
# strict isolated layout breaks old plugins that rely on hoisting.
node-linker=hoisted

# npm fallback only: this project has conflicting peer ranges
# (@enyaxu/markdown-it-anchor wants markdown-it@8, project uses @6). pnpm treats
# peer mismatches as warnings (not errors), so pnpm install works without this.
legacy-peer-deps=true
